with nesto as(
select customer_id,row_number() over(partition by customer_id order by order_date asc) as renk,case when order_date = customer_pref_delivery_date then 'immediate' else 'scheduled' end as dal
from delivery

)
select top 1 round(avg(case when dal = 'immediate' then 1*100.00 else 0 end) over(),2) as immediate_percentage
from nesto
where renk = 1
